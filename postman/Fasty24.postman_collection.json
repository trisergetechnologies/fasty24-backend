{
  "info": {
    "name": "Fasty-24 API",
    "description": "On-demand home services API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "bookingId", "value": "" },
    { "key": "orderId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"phone\":\"+919876543210\"}" },
            "url": "{{baseUrl}}/auth/otp/send"
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"phone\":\"+919876543210\",\"code\":\"123456\"}" },
            "url": "{{baseUrl}}/auth/otp/verify"
          }
        }
      ]
    },
    {
      "name": "Catalog",
      "item": [
        {
          "name": "List Categories",
          "request": { "method": "GET", "url": "{{baseUrl}}/catalog/categories" }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"serviceId\":\"SERVICE_ID\",\"address\":{\"line1\":\"123 Main St\",\"city\":\"Delhi\",\"pincode\":\"110001\",\"lat\":28.6139,\"lng\":77.2090}}"
            },
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "Confirm Dev Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"orderId\":\"{{orderId}}\"}" },
            "url": "{{baseUrl}}/payments/dev/confirm"
          }
        }
      ]
    },
    {
      "name": "Staff",
      "item": [
        {
          "name": "Go Online",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"isOnline\":true}" },
            "url": "{{baseUrl}}/staff/status"
          }
        },
        {
          "name": "Accept Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Idempotency-Key", "value": "accept-{{bookingId}}" }
            ],
            "url": "{{baseUrl}}/staff/jobs/{{bookingId}}/accept"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/categories"
          }
        },
        {
          "name": "Live Ops",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/ops/live"
          }
        }
      ]
    }
  ]
}
